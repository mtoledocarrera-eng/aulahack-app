# ══════════════════════════════════════════════
# 360Hacks — Variables de Entorno
# ══════════════════════════════════════════════
# Copia este archivo como .env.local y completa los valores.

# ─── Google AI (Gemini) ───────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSyA5DEYbfBLCwaMqlLKafHaYjrOXpUSCVBo

# Modelo primario y fallback
AI_MODEL_PRIMARY=gemini-2.5-flash
AI_MODEL_FALLBACK=gemini-2.0-flash

# ─── Firebase ─────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_ADMIN_UID=your_admin_uid_from_firebase_auth

# ─── Flow.cl (Pagos) ─────────────────────────
FLOW_API_KEY=your_flow_api_key
FLOW_SECRET_KEY=your_flow_secret_key
FLOW_ENVIRONMENT=sandbox
# sandbox | production

# ─── App Config ───────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
